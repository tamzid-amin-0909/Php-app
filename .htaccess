RewriteEngine On

# 1. Force HTTPS Redirect
RewriteCond %{SERVER_PORT} 80
RewriteRule ^(.*)$ https://everythingfree.iceiy.com/$1 [R,L]

# 2. FIX FOR 401 ERROR (Crucial for your patchContent function)
# This passes the Bearer token from the header to PHP
RewriteCond %{HTTP:Authorization} ^(.*)
RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]

# 3. Enable ETags
FileETag MTime Size

# 4. Headers & CORS
<IfModule mod_headers.c>
    # Tells browser to re-validate cache
    Header set Cache-Control "no-cache, must-revalidate"
    
    # Allows your JS to talk to the API from different origins if needed
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "POST, GET, OPTIONS, PATCH"
    Header set Access-Control-Allow-Headers "Content-Type, Authorization"
</IfModule>
